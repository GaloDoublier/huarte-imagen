generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//categorias
model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?   // descripcion breve de la cat
  slogan      String?   //slogan/chamuyo Ej: Maquillaje -> "Realza tu belleza"
  services    Service[] // Relación hacia los servicios
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// Servicios Maq/Est
model Service {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Int
  duration    String
  imageUrl    String?
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  
  // Relacion categoria
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Configuracion del sitio (singleton)
model SiteConfig {
  id        String   @id @default(cuid())
  
  // General
  siteName           String   @default("Huarte Imagen")
  
  // Contacto / Redes
  whatsappNumber     String   @default("")
  instagramUrl       String   @default("")
  email              String   @default("")
  
  // Programa Online
  hotmartUrl         String   @default("")
  
  // About — bio + 3 stats
  aboutBio           String   @default("")
  aboutStat1Value    String   @default("8+")
  aboutStat1Label    String   @default("Años de experiencia")
  aboutStat2Value    String   @default("500+")
  aboutStat2Label    String   @default("Clientas transformadas")
  aboutStat3Value    String   @default("100%")
  aboutStat3Label    String   @default("Dedicación personal")
  
  // Announcement Bar
  announcementMessage String  @default("")
  announcementActive  Boolean @default(false)
  announcementLink    String?
  
  // Testimonios
  testimonials        Json    @default("[]")
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}