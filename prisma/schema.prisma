generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Servicios Maq/Est
model Service {
  id          String   @id @default(cuid())
  name        String
  category    String   // cats: "Maquillaje", "Estética"
  description String
  price       Int 
  duration    String?
  imageUrl    String? 
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}